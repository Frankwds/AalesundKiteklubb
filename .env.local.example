# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (public, used by Supabase SDK at runtime)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only, bypasses RLS for admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# Resend API key (server-only, for sending emails)
RESEND_API_KEY=

# FROM address for emails (use onboarding@resend.dev for dev)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Full origin of the app (used for OAuth redirect URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Soft flag: "true" shows Kurs in navbar + admin tab. Omit or any other value hides them; /courses still works.
NEXT_PUBLIC_SHOW_COURSE_PAGES=

# Google Maps API key (client-side: admin map picker + kite zones editor; also Static Maps on server for public spot images). Enable "Maps JavaScript API" and "Maps Static API" in Google Cloud for this key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
